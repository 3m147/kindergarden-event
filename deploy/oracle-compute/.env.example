# Public API hostname. Replace PUBLIC_IP with the Oracle Compute public IPv4.
# nip.io resolves this hostname to the embedded IP and lets Caddy issue HTTPS.
API_DOMAIN=api.PUBLIC_IP.nip.io

ORACLE_DB_USERNAME=KINDERGARDEN_APP
ORACLE_DB_PASSWORD=replace-with-database-password

# Generate with: openssl rand -base64 48
APP_JWT_SECRET=replace-with-at-least-32-random-characters

# Set this after the Vercel deployment URL is known.
APP_ALLOWED_ORIGINS=https://your-project.vercel.app
